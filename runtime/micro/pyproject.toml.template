[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{harness_name}}"
version = "0.1.0"
description = "Pico standalone constrained agent — {{harness_name}}"
requires-python = ">=3.11"
license = "MIT"
dependencies = [
    "litellm>=1.0",
    "pyyaml>=6.0",
    "rich>=13.0",
]

[project.scripts]
{{harness_name}} = "{{package_name}}.cli:main"

[tool.hatch.build.targets.wheel]
packages = ["{{package_name}}"]
